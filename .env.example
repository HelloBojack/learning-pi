# 网关根地址；若已包含完整路径（如 /v1/chat/completions），则无需 API_CHAT_PATH
API_URL=https://your-llm-gateway.example.com
API_KEY=sk-your-key

# 可选：仅当 API_URL 为域名根路径时生效
# API_CHAT_PATH=/v1/chat/completions
# API_MODEL=gpt-4o-mini

# 可选：固定 system prompt（设置后 REPL 内 /code 等 preset 切换会失效）
# SYSTEM_PROMPT=你是一个简洁的编程助教，只回答 TypeScript 相关问题。
# 更推荐在 REPL 里用 /code、/translate 等命令切换预设，见 /help

# 可选：上下文 token 上限（/tokens 展示用；默认 8192）
# CONTEXT_TOKEN_LIMIT=8192

# 可选：网关一次返回整段 SSE 时，加大延迟让打字效果更明显（毫秒，如 20）
# STREAM_DELAY_MS=20
